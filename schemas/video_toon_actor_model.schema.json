{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/reverie/video_toon_actor_model.schema.json",
  "title": "Reverie Video-Toon Actor Model",
  "type": "object",
  "required": [
    "actor_id",
    "template_version",
    "readiness_state",
    "template_goal",
    "reuse_contract",
    "identity_lock",
    "required_variants",
    "mouth_shapes",
    "eye_shapes",
    "public_release_boundary"
  ],
  "additionalProperties": true,
  "properties": {
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "template_version": {
      "type": "string",
      "minLength": 1
    },
    "readiness_state": {
      "type": "string",
      "enum": ["template", "draft", "ready_for_test", "approved", "retired"]
    },
    "age_band": {
      "type": "string",
      "minLength": 1
    },
    "gender_presentation": {
      "type": "string",
      "minLength": 1
    },
    "role_range": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "template_goal": {
      "type": "object",
      "required": ["goal_id", "is_primary_template", "target_actor_id", "target_use", "reuse_surfaces"],
      "additionalProperties": true,
      "properties": {
        "goal_id": {
          "type": "string",
          "minLength": 1
        },
        "is_primary_template": {
          "type": "boolean"
        },
        "target_actor_id": {
          "type": "string",
          "minLength": 1
        },
        "target_use": {
          "type": "string",
          "minLength": 1
        },
        "reuse_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "reuse_contract": {
      "type": "object",
      "required": [
        "identity_is_fixed",
        "roles_may_change_by_episode",
        "background_may_change_by_episode",
        "requires_asset_coverage_before_render"
      ],
      "additionalProperties": true,
      "properties": {
        "identity_is_fixed": {
          "type": "boolean"
        },
        "roles_may_change_by_episode": {
          "type": "boolean"
        },
        "background_may_change_by_episode": {
          "type": "boolean"
        },
        "wardrobe_policy": {
          "type": "string"
        },
        "allowed_pack_overrides": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "must_not_change": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requires_asset_coverage_before_render": {
          "type": "boolean"
        }
      }
    },
    "identity_lock": {
      "type": "object",
      "required": ["must_not_change"],
      "additionalProperties": true,
      "properties": {
        "face_shape": {
          "type": "string"
        },
        "hair": {
          "type": "string"
        },
        "body_type": {
          "type": "string"
        },
        "signature_clothing": {
          "type": "string"
        },
        "must_not_change": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "style_contract": {
      "type": "object",
      "additionalProperties": true
    },
    "required_variants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mouth_shapes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "eye_shapes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "voice_profile": {
      "type": "object",
      "additionalProperties": true
    },
    "public_release_boundary": {
      "type": "object",
      "required": [
        "contains_real_actor_media",
        "contains_voice_samples",
        "contains_model_weights",
        "contains_private_paths"
      ],
      "additionalProperties": true,
      "properties": {
        "contains_real_actor_media": {
          "type": "boolean",
          "const": false
        },
        "contains_voice_samples": {
          "type": "boolean",
          "const": false
        },
        "contains_model_weights": {
          "type": "boolean",
          "const": false
        },
        "contains_private_paths": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
