# Reverie Studio open-source local environment template
#
# Copy this file to `.env` for local-only experimentation.
# Keep `.env` untracked. Do not put real keys, OAuth tokens, Firebase service
# accounts, generated output paths, or private operator data in the repository.

# Optional LLM/API keys. Leave blank in the public repository.
GEMINI_API_KEY=
YOUTUBE_API_KEY=
OPENAI_API_KEY=

# Local service endpoints.
SD_URL=http://127.0.0.1:7860
SOVITS_URL=http://127.0.0.1:9880
COMFYUI_URL=http://127.0.0.1:8188

# Local tool roots. Replace with machine-local paths in `.env` only.
SD_WEBUI_ROOT=
GS_ROOT=
SOVITS_ROOT=
COMFYUI_ROOT=
FFMPEG_PATH=

# External asset roots. Users should provide these locally.
# Do not commit voice datasets, BGM/SFX libraries, LoRA files, checkpoints, or
# generated media to this repository.
VOICE_DATASET_ROOT=
BGM_LIBRARY_ROOT=
SFX_LIBRARY_ROOT=
LORA_MODEL_ROOT=
CHECKPOINT_MODEL_ROOT=

# Startup behavior.
AUTO_START_SERVERS=false
AUTO_START_LIST=SD WebUI,GPT-SoVITS
TEST_MODE=true
REVERIE_DEV_MODE=false

# Rendering and generation defaults.
RENDER_ENGINE=auto
REMOTION_CONCURRENCY=2
TTS_ENGINE=sovits
TTS_FALLBACK_ENABLED=true
TTS_HYBRID_ENABLED=false

# Optional Supertonic 3 local TTS backend.
# Set TTS_ENGINE=supertonic after installing the optional package:
#   pip install supertonic
# Built-in voices: M1-M5 and F1-F5. This repo does not include voice assets.
SUPERTONIC_AUTO_DOWNLOAD=true
SUPERTONIC_DEFAULT_VOICE=M1
SUPERTONIC_VOICE_MAP=narrator=M1,grandpa=M2,grandma=F2,middle_man=M3,middle_woman=F3,young_man=M4,young_woman=F4,child=F5
SUPERTONIC_TOTAL_STEPS=5
SUPERTONIC_SPEED=1.05
SUPERTONIC_MAX_CHUNK_LENGTH=120
SUPERTONIC_SILENCE_DURATION=0.25
SUPERTONIC_INTRA_OP_THREADS=0
SUPERTONIC_INTER_OP_THREADS=0

# Optional video-toon workspace. Keep generated assets outside git.
VIDEOTOON_WORKSPACE_ROOT=
VIDEOTOON_IMAGE_BACKEND=comfyui
VIDEOTOON_MAX_PARALLEL_IMAGE_JOBS=1

# Pack encryption / signing placeholders.
REVERIE_SECRET_KEY=
REVERIE_PACK_PASSWORD=
REVERIE_PACK_SALT=
REVERIE_PACK_ALLOW_LEGACY_KEY=0
REVERIE_PACK_REQUIRE_ENCRYPTED=0
REVERIE_PACK_REQUIRE_SIGNATURE=0
REVERIE_PACK_STRICT_ACCESS=0

# Optional admin metadata placeholder. Do not use personal identifiers here.
REVERIE_ADMIN_ORG_NAME=Reverie Studio Local
